{
	"$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",

	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},

	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSpacing": true
		}
	},

	"css": {
		"formatter": {
			"enabled": true
		}
	},

	"files": {
    
	}
}
