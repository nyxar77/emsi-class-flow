        <h1 className="text-2xl font-black text-[#4c4f69] dark:text-[#cdd6f4]">Tableau de bord</h1>
        <p className="text-sm text-[#9ca0b0] dark:text-[#6c7086] mt-0.5">
          Vue d'ensemble — EMSI Campus · Mardi 14 Jan 2025
        </p>
